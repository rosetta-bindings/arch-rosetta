{
    "//": "Rosetta binding manifest for arch3. Mirrors the hand-written pybind11",
    "//2": "bindings in ../python/binding_*.cxx. Class/function names are fully",
    "//3": "qualified C++ types (they are spliced into binding_info<T> / ^^fn).",
    "//4": "Headers are relative to user_include (extern/arch/include).",
    "//5": "Generate: extern/rosetta/bin/rosetta_gen manifest.json gen",
    "cpp26_root": "$ENV{HOME}/devs/c++/clang-p2996/build",
    "cpp26_cxx": "$ENV{HOME}/devs/c++/clang-p2996/build/bin/clang++",
    "cpp26_cc": "$ENV{HOME}/devs/c++/clang-p2996/build/bin/clang",
    "cpp26_lib": "$ENV{HOME}/devs/c++/clang-p2996/build/lib",
    "user_include": [
        "extern/arch/include",
        "extern/eigen",
        "extern/krylov/include"
    ],
    "//sources": "arch3 implementation .cxx files compiled straight into every binding target (no prebuilt lib). Globs are non-recursive POSIX, so each src subdir is listed explicitly. Re-run rosetta_gen after adding/removing source dirs.",
    "user_sources": [
        "extern/arch/src/*.cxx",
        "extern/arch/src/algos/*.cxx",
        "extern/arch/src/algos/pore-pressure/*.cxx",
        "extern/arch/src/algos/slip-inversion/*.cxx",
        "extern/arch/src/algos/stress-inversion/*.cxx",
        "extern/arch/src/choubidou/*.cxx",
        "extern/arch/src/concurrent/*.cxx",
        "extern/arch/src/core/*.cxx",
        "extern/arch/src/dataframe/*.cxx",
        "extern/arch/src/dataframe/math/*.cxx",
        "extern/arch/src/filters/*.cxx",
        "extern/arch/src/hmatrix/*.cxx",
        "extern/arch/src/io/*.cxx",
        "extern/arch/src/math/*.cxx",
        "extern/arch/src/postprocess/*.cxx",
        "extern/arch/src/solvers/*.cxx",
        "extern/arch/src/temperature/*.cxx",
        "extern/arch/src/utils/*.cxx"
    ],
    "rosetta_include": "extern/rosetta/include",
    "generator_name": "arch",
    "module_name": "arch",
    "targets": [
        {
            "lang": "python",
            "name": "arch"
        },
