{
    "//": "Rosetta binding manifest for arch3. Mirrors the hand-written pybind11",
    "//2": "bindings in ../python/binding_*.cxx. The top-level namespace/header_dir",
    "//3": "defaults qualify every unqualified name with arch:: and prefix every",
    "//4": "header with Arch/ (names carrying their own :: — df::Serie, arch::sinv::*",
    "//5": "— pass verbatim; an omitted name derives from the header stem).",
    "//6": "Headers are relative to user_include (extern/arch/include).",
    "//7": "Generate: extern/rosetta/bin/rosetta_gen manifest.json gen",
    "cpp26_root": "$ENV{HOME}/devs/c++/clang-p2996/build",
    "cpp26_cxx": "$ENV{HOME}/devs/c++/clang-p2996/build/bin/clang++",
    "cpp26_cc": "$ENV{HOME}/devs/c++/clang-p2996/build/bin/clang",
    "cpp26_lib": "$ENV{HOME}/devs/c++/clang-p2996/build/lib",
    "user_include": [
        "extern/arch/include",
        "extern/eigen",
        "extern/krylov/include"
    ],
    "//sources": "arch3 implementation .cxx files compiled straight into every binding target (no prebuilt lib). ** matches zero or more directories (globstar), so this one pattern covers src/ and every subdirectory. Re-run rosetta_gen after adding/removing source files.",
    "user_sources": [
        "extern/arch/src/**/*.cxx"
    ],
    "rosetta_include": "extern/rosetta/include",
    "generator_name": "arch",
    "module_name": "arch",
    "namespace": "arch",
    "header_dir": "Arch",
    "targets": [
        {"lang": "python-expanded",        "name": "arch"},
        {"lang": "node-expanded",          "name": "arch"},
        {"lang": "wasm-expanded", "name": "arch"},
        {"lang": "typescript",    "name": "arch"}
    ],
    "classes": [
        {"//": "--- math ---", "header": "math/math.h", "entries": [
            {"name": "Vector3"},
            {"name": "Matrix33"}
        ]},

        {"//": "--- dataframe ---", "name": "df::Serie", "header": "dataframe/Serie.h"},

        {"//": "--- core ---", "header_dir": "core", "entries": [
            {"header": "Model.h"},
            {"header": "Surface.h"},
            {"//": "remotes", "header": "Remote.h", "entries": [
                {"name": "BaseRemote"},
                {"name": "RemoteStress"},
                {"name": "UserRemote"}
            ]},
            {"//": "inequality constraints (TIC / DIC)", "header": "Inequality.h", "entries": [
                {"name": "Tic"},
                {"name": "Dic"},
                {"name": "FunctionalTic"},
                {"name": "FunctionalDic"},
                {"name": "Coulomb"}
            ]}
        ]},

        {"//": "--- temperature ---", "header": "temperature/TemperatureField.h"},

        {"//": "--- solvers ---", "header_dir": "solvers", "entries": [
            {"name": "GmresSolver",  "header": "Gmres.h"},
            {"name": "JacobiSolver", "header": "Jacobi.h"},
            {"name": "SeidelSolver", "header": "Seidel.h"},
            {"header": "ParallelSolver.h"},
            {"header": "HMatrixGmresSolver.h"},
            {"header": "HMatrixIterativeSolver.h"},
            {"header": "HMatrixJacobiSolver.h"},
            {"header": "HMatrixSeidelSolver.h"},
            {"header": "HMatrixParallelGmresSolver.h"},
            {"header": "H2MatrixGmresSolver.h"}
        ]},

        {"//": "--- postprocess ---", "header_dir": "postprocess", "entries": [
            {"header": "Postprocess.h"},
            {"header": "ParallelPostprocess.h"},
            {"header": "HPostprocess.h"},
            {"header": "HMatrixParallelPostprocess.h"}
        ]},

        {"//": "--- algos ---", "header_dir": "algos", "entries": [
            {"header": "DataSuperposition.h"},
            {"header": "CoulombSuperposition.h"},
            {"header": "FrictionInversion.h"},

            {"//": "stress inversion", "namespace": "sinv", "header_dir": "stress-inversion", "entries": [
                {"header": "Data.h"},
                {"header": "JointData.h"},
                {"header": "StyloliteData.h"},
                {"header": "DykeData.h"},
                {"header": "ConjugateData.h"},
                {"header": "GpsData.h"},
                {"header": "InsarData.h"},
                {"header": "ShearFractureData.h"},
                {"header": "ShearPlaneData.h"},
                {"header": "MCInversion.h"},
                {"header": "MCMCInversion.h"},
                {"header": "types.h", "entries": [
                    {"name": "AlphaParameter"},
                    {"name": "InversionResult"},
                    {"name": "MCMCChainEntry"},
                    {"name": "MCMCConfig"},
                    {"name": "MCMCResult"}
                ]}
            ]}
        ]}
    ],
    "functions": [
        {
            "doc": "Eigen decomposition of a stress tensor",
            "name": "stressEigen",
            "header": "algos/stress-inversion/StressUtils.h"
        }
    ]
}
